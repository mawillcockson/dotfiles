{{ $shell := deepCopy . |
    merge (dict "exes" (list
        "nu"
        "pwsh"
    )) |
    includeTemplate "findExe"
}}
{{ if $shell }}
terminal.shell.program = {{ toToml $shell }}
{{ end }}

{{ if findExecutable "bash" (list $egetBin (env "PATH")) }}
[[keyboard.bindings]]
key = "M"
mods = "Control|Shift"
mode = "~Search"
command = { program = "alacritty", args = ["--command", "bash"]}
{{ else }}
[[keyboard.bindings]]
key = "M"
mods = "Control|Shift"
mode = "~Search"
command = { program = "alacritty", args = ["--command", "sh"]}
{{ end }}
