(deflayermap (arrows)
  h left
  j down
  k up
  l right
  e (layer-while-held numpad)
  w вҖ№вҮ§
)
|#

(deflayer cluster
  _      _    _    _    _         _    _    _    _    _   _   _    _
  _    _    _    _    _    _    _    _    _    _    _    _    _    _
  _    _    вҖ№вҮ§   _    _    _    _    _    _    bspc del  _    _    _
  _    _    _    _    _    _    Home pgdn pgup End  _    _    _
  _    _    _    _    _    _    _    _    _    _    _    _
  _    _    _              _              _    _    _   _
)

#|
(deflayermap (cluster)
  h Home
  l End
  j PageDown
  k PageUp
  o Backspace
  p Delete
  w ShiftLeft
)
|#

(deflayer numpad
