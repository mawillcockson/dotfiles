# don't use the user-level tmux config if the system one exists
{{ if stat "/etc/tmux.conf" }}
    {{ $tmux_conf := joinPath (.chezmoi.config.env.XDG_CONFIG_HOME) "tmux" "tmux.conf" | osClean }}
    {{ if osIsAbs $tmux_conf }}
{{
            deepCopy . |
            merge (dict
                "makeRelative" $tmux_conf
                "relativeTo" .chezmoi.destDir
            ) |
            includeTemplate "relativeTo"
        }}
    {{ else }}
{{ $tmux_conf }}
    {{ end }}
{{ end }}
